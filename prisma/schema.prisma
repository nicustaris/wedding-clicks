generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("WEDDINGCLICKS_DATABASE_URL")
  directUrl = env("WEDDINGCLICKS_DATABASE_URL_UNPOOLED")
}

model User{ 
  id String @id @default(cuid())
  name String
  email String @unique
  password String?
  picture String?
  accounts Account[]
}

model Account {
  id String @id @default(cuid())
  userId String
  provider String
  providerAccountId String
  
  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Event {
    id Int @id @default(autoincrement())
    creator String
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())

    sessions SessionRecord[]
}

model Media {
    id Int @id @default(autoincrement())
    sessionId Int
    url String
    optimizedUrl String
    thumbnailUrl String
    mediaType String
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())

    sessionRecord SessionRecord @relation(fields: [sessionId], references: [id])
}

model SessionRecord {
  id Int @id @default(autoincrement())
  name String
  message String
  eventId Int

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])
  media Media[]
}